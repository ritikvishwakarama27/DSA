def find_smallest(arr):
    if arr is None or len(arr) == 0:
        raise ValueError("Array must not be empty")

    min_val = arr[0]
    for num in arr[1:]:
        if num < min_val:
            min_val = num
    return min_val

if __name__ == "__main__":
    arr = [5, 2, 9, 8, 6]
    smallest = find_smallest(arr)
    print("Smallest number is:", smallest)
